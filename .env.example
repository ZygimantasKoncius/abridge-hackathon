# Anthropic — used by the extraction + (later) analysis pipeline.
# The SDK also picks up an `ant auth login` profile if this is unset.
ANTHROPIC_API_KEY=

# Optional: override the extraction model. Defaults to claude-opus-4-8.
# The spec allows claude-sonnet-4-6 as a drop-in for the extraction batch if
# the 56-entry seed run feels slow/pricey during dev. Keep Opus for analysis.
# EXTRACTION_MODEL=claude-opus-4-8

# Optional: override the digest-analysis model. Defaults to claude-opus-4-8
# (the judgment-heavy prose surface — keep it on Opus).
# ANALYSIS_MODEL=claude-opus-4-8

# Optional: override the SQLite file location (defaults to ./data/abridge.db).
# ABRIDGE_DB_PATH=

# OpenAI — powers the patient voice check-in (/journal). The realtime voice
# token mint (§5b) is frontend-owned: /api/realtime-session uses this key to
# mint a short-lived ephemeral client secret; the standard key never reaches the
# browser. Required for the voice flow.
OPENAI_API_KEY=

# Optional: override the realtime voice model. Defaults to gpt-realtime-2.
# OPENAI_REALTIME_MODEL=gpt-realtime-2
